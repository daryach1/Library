<Window x:Class="LibraryDesktop.Windows.AddBookWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LibraryDesktop.Windows"
        mc:Ignorable="d"
        Title="Добавить книгу" 
        Height="400" 
        Width="600"
        Icon="/Resources/LibraryIcon.ico"
        WindowStartupLocation="CenterScreen"
        MinHeight="300"
        MinWidth="400"
        MaxHeight="400"
        MaxWidth="600">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition/>
            <RowDefinition Height="50"/>
        </Grid.RowDefinitions>
        <!--#region  StackPanel Row 0-->
        <StackPanel Orientation="Horizontal"
                    Grid.Row="0">
            <StackPanel.Background>
                <ImageBrush ImageSource="/Resources/BackgroudLibrary.jpg"
                            Stretch="UniformToFill"
                            Opacity="0.4"/>
            </StackPanel.Background>
            <TextBlock Text="Добавление книги"
                       VerticalAlignment="Center"
                       Margin="20,0,0,0"
                       FontSize="20"
                       FontStyle="Italic"
                       FontWeight="Heavy"/>
        </StackPanel>
        <!--#endregion-->
        <!--#region UniformGrid Row 1-->
        <UniformGrid Columns="2"
                     Grid.Row="1"
                     Width="500"
                     Margin="0,10,0,10">
            <TextBlock Text="Название книги: "
                       Style="{StaticResource TextBlockStyle}"/>
            <TextBox Text="{Binding Title}"
                     Style="{StaticResource TextBoxStyle}"
                     x:Name="TitleTextBox"/>
            <TextBlock Text="Автор: "
                       Style="{StaticResource TextBlockStyle}"/>
            <TextBox Text="{Binding Author}"
                     Style="{StaticResource TextBoxStyle}"
                     x:Name="AuthorTextBox"/>
            <TextBlock Text="Жанр: "
                       Style="{StaticResource TextBlockStyle}"/>
            <TextBox Text="{Binding Genre}"
                     Style="{StaticResource TextBoxStyle}"
                     x:Name="GenreTextBox"/>
            <TextBlock Text="Количество экземпляров:"
                       Style="{StaticResource TextBlockStyle}"/>
            <TextBox Text="{Binding TotalCopies}"
                     Style="{StaticResource TextBoxStyle}"
                     x:Name="TotalCopiesTextBox"/>
            <TextBlock Text="Доступно: "
                       Style="{StaticResource TextBlockStyle}"/>
            <TextBox Text="{Binding AvailableCopies}"
                     Style="{StaticResource TextBoxStyle}"
                     x:Name="AvailableCopiesTextBox"/>
        </UniformGrid>
        <!--#endregion-->
        <!--#region Grid and StackPanel Row 2-->
        <Grid Grid.Row="2"
              Background="#efe2cf">
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Center">
                <Button x:Name="AddButton"
                        Content="Добавить"
                        Style="{StaticResource ButtonStyle}"
                        Margin="0,0,20,0"
                        Click="AddButton_Click"/>
                <Button x:Name="CloseButton"
                        Content="Отмена"
                        Style="{StaticResource ButtonStyle}"
                        Click="CloseButton_Click"/>
            </StackPanel>
        </Grid>
        <!--#endregion-->
    </Grid>
</Window>
