<Window x:Class="LibraryDesktop.Windows.MainLibrary"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LibraryDesktop"
        mc:Ignorable="d"
        Title="Библиотека" 
        Height="450" 
        Width="800"
        MinHeight="450"
        MinWidth="800"
        WindowStartupLocation="CenterScreen"
        Icon="/Resources/LibraryIcon.ico">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <!--#region StackPanel Row 0-->
        <StackPanel Orientation="Vertical"
                    Grid.Row="0">
            <StackPanel.Background>
                <ImageBrush ImageSource="/Resources/BackgroudLibrary.jpg"
                            Stretch="UniformToFill"
                            Opacity="0.4"/>
            </StackPanel.Background>
            <TextBlock Text="Библиотека"
                       HorizontalAlignment="Center"
                       FontSize="20"
                       FontStyle="Italic"
                       FontWeight="UltraBold"/>
            <TextBlock Text="Добро пожаловать!"
                       HorizontalAlignment="Center"
                       Margin="0,10,0,0"
                       FontSize="15"
                       FontStyle="Italic"
                       FontWeight="Heavy"/>
        </StackPanel>
        <!--#endregion-->
        <!--#region Frame Row 1-->
        <Frame x:Name="MainFrame"
               Grid.Row="1"
               NavigationUIVisibility="Hidden"/>
        <!--#endregion-->
    </Grid>
</Window>
