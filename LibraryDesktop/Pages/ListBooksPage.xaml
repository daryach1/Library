<Page x:Class="LibraryDesktop.Pages.ListBooksPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:LibraryDesktop.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ListBooksPage"
      Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="45"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="30"/>
        </Grid.RowDefinitions>
        <!--#region StackPanel Row 0-->
        <StackPanel Orientation="Horizontal"
                    Background="#efe2cf">
            <Button x:Name="AddBookButton"
                    Content="Добавить книгу"
                    Margin="10,0,0,0"
                    Style="{StaticResource ButtonStyle}"
                    Click="AddBookButton_Click"/>
            <Button x:Name="UpdateDataButton"
                    Content="Обновить"
                    Margin="10,0,0,0"
                    Style="{StaticResource ButtonStyle}"
                    Click="UpdateDataButton_Click"/>
        </StackPanel>
        <!--#endregion-->
        <!--#region ListView Row 1-->
        <ListView x:Name="BooksListView"
                  Grid.Row="1"
                  SizeChanged="BooksListView_SizeChanged">
            <ListView.ItemContainerStyle>
                <Style TargetType="ListViewItem">
                    <Setter Property="Margin" 
                            Value="0,0,0,1"/>
                    <Setter Property="BorderBrush" 
                            Value="LightGray"/>
                    <Setter Property="BorderThickness" 
                            Value="0,0,0,1"/>
                    <Setter Property="FontSize"
                            Value="16"/>
                    <Setter Property="HorizontalContentAlignment"
                            Value="Center"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" 
                                 Value="True">
                            <Setter Property="Background" 
                                    Value="#ccba8b"/>
                            <Setter Property="FontWeight" 
                                    Value="Bold"/>
                        </Trigger>
                        <Trigger Property="IsMouseOver" 
                                 Value="True">
                            <Setter Property="Background" 
                                    Value="LightGreen"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </ListView.ItemContainerStyle>
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="Название"
                                    x:Name="TitleColumn"
                                    DisplayMemberBinding="{Binding Title}"
                                    Width="200"/>
                    <GridViewColumn Header="Жанр"
                                    x:Name="GenreColumn"
                                    DisplayMemberBinding="{Binding Genre}"
                                    Width="200"/>
                    <GridViewColumn Header="Автор"
                                    x:Name="AuthorColumn"
                                    DisplayMemberBinding="{Binding Author}"
                                    Width="200"/>
                    <GridViewColumn Header="Количество экземпляров"
                                    x:Name="TotalCopiesColumn"
                                    DisplayMemberBinding="{Binding TotalCopies}"
                                    Width="100"/>
                    <GridViewColumn Header="Количество доступных книг"
                                    x:Name="AvailableCopiesColumn"
                                    DisplayMemberBinding="{Binding AvailableCopies}"
                                    Width="100"/>
                </GridView>
            </ListView.View>
        </ListView>
        <!--#endregion-->
        <!--#region Grid and StackPanel Row 2-->
        <Grid Grid.Row="2"
              Background="#efe2cf">
            <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">
                <TextBlock Text="Общее кол-во книг: "
                           Style="{StaticResource TextBlockStyle}"/>
                <Label x:Name="TotalBookLabel"
                       FontSize="16"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"/>
                <TextBlock Text="Доступное кол-во в библиотеке: "
                           Style="{StaticResource TextBlockStyle}"
                           Margin="20,0,0,0"/>
                <Label x:Name="TotalAvailableBookLabel"
                       FontSize="16"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"/>
            </StackPanel>
        </Grid>
        <!--#endregion-->
    </Grid>
</Page>
